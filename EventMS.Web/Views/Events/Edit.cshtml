@model Event
@{ ViewData["Title"] = "Edit Event"; }

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-secondary text-white fw-bold">
                <i class="bi bi-pencil-square me-2"></i>Edit Event
            </div>
            <div class="card-body">
                <form asp-action="Edit" method="post">
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="CreatedAt" />
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label fw-semibold"></label>
                        <input asp-for="Title" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label fw-semibold"></label>
                        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                    </div>

                    <div class="row g-2 mb-3">
                        <div class="col-md-4">
                            <label asp-for="Category" class="form-label fw-semibold"></label>
                            <select asp-for="Category" class="form-select">
                                @foreach (EventCategory cat in (Array)ViewBag.Categories)
                                {
                                    <option value="@cat">@cat</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Status" class="form-label fw-semibold"></label>
                            <select asp-for="Status" class="form-select">
                                @foreach (EventStatus st in (Array)ViewBag.Statuses)
                                {
                                    <option value="@st">@st</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="OrganizerName" class="form-label fw-semibold"></label>
                            <input asp-for="OrganizerName" class="form-control" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Venue" class="form-label fw-semibold"></label>
                        <input asp-for="Venue" class="form-control" />
                    </div>

                    <div class="row g-2 mb-3">
                        <div class="col-md-5">
                            <label asp-for="EventDate" class="form-label fw-semibold"></label>
                            <input asp-for="EventDate" type="datetime-local" class="form-control" />
                        </div>
                        <div class="col-md-3">
                            <label asp-for="MaxCapacity" class="form-label fw-semibold"></label>
                            <input asp-for="MaxCapacity" type="number" class="form-control" min="1" />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="TicketPrice" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <span class="input-group-text">৳</span>
                                <input asp-for="TicketPrice" type="number" class="form-control" min="0" />
                            </div>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-secondary px-4">
                            <i class="bi bi-save me-1"></i>Update
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
