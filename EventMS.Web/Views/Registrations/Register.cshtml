@{ ViewData["Title"] = "Register for Event"; }

@{
    var ev = ViewBag.Event as Event;
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-success text-white fw-bold">
                <i class="bi bi-ticket-perforated me-2"></i>Register for Event
            </div>
            <div class="card-body">
                @if (ev != null)
                {
                    <div class="alert alert-light border mb-3">
                        <div class="fw-bold">@ev.Title</div>
                        <div class="small text-muted">
                            <i class="bi bi-geo-alt me-1"></i>@ev.Venue
                            &nbsp;|&nbsp;
                            <i class="bi bi-calendar3 me-1"></i>@ev.EventDate.ToString("dd MMM yyyy, hh:mm tt")
                        </div>
                        <div class="small text-muted">
                            <i class="bi bi-people me-1"></i>@ev.AvailableSeats seats left
                            &nbsp;|&nbsp;
                            <span class="fw-bold text-success">৳@ev.TicketPrice.ToString("N0")</span>
                        </div>
                    </div>
                }

                <div asp-validation-summary="All" class="text-danger mb-3"></div>

                <form asp-action="Register" method="post">
                    <input type="hidden" name="eventId" value="@ev?.Id" />

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Full Name <span class="text-danger">*</span></label>
                        <input name="name" class="form-control" placeholder="Your full name" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Email Address <span class="text-danger">*</span></label>
                        <input name="email" type="email" class="form-control" placeholder="your@email.com" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Phone Number</label>
                        <input name="phone" class="form-control" placeholder="01XXXXXXXXX (optional)" />
                    </div>

                    <div class="alert alert-info small">
                        <i class="bi bi-info-circle me-1"></i>
                        A unique <strong>Booking ID</strong> will be generated upon successful registration.
                        Keep it for check-in at the event.
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success px-4">
                            <i class="bi bi-check-lg me-1"></i>Confirm Registration
                        </button>
                        <a asp-controller="Events" asp-action="Details" asp-route-id="@ev?.Id"
                           class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
